generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Instance {
  id        String    @id @default(uuid())
  name      String
  status    String    @default("disconnected")
  color     String    @default("#3b82f6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  botPrompt String?   @default("Você é um assistente virtual prestativo.")
  knowledge String?   @default("[]")
  flows     Flow[]
  chats     Chat[]
  messages  Message[]
}

model Flow {
  id         String    @id @default(uuid())
  name       String
  trigger    String    @default("whatsapp.inbound")
  status     String    @default("Rascunho")
  data       String
  instanceId String?
  instance   Instance? @relation(fields: [instanceId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Chat {
  id          String   @id @default(uuid())
  instanceId  String
  jid         String
  name        String?
  unreadCount Int      @default(0)
  lastMsg     String?
  lastMsgTime String?
  aiEnabled   Boolean  @default(false)
  isGroup     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  instance    Instance @relation(fields: [instanceId], references: [id])
  messages    Message[]

  @@unique([instanceId, jid])
}

model Message {
  id                String   @id @default(uuid())
  msgId             String   @unique
  instanceId        String
  jid               String
  text              String
  fromMe            Boolean
  participant       String?
  senderName        String?
  quotedText        String?
  quotedParticipant String?
  timestamp         DateTime @default(now())
  status            String   @default("sent")
  instance          Instance @relation(fields: [instanceId], references: [id])
  chat              Chat     @relation(fields: [instanceId, jid], references: [instanceId, jid])

  @@index([instanceId, jid])
}

// Agendamentos / Pedidos
model Order {
  id              String   @id @default(cuid())
  instanceId      String
  clientName      String?
  clientJid       String?
  product         String
  quantity        String?
  notes           String?
  scheduledDate   String
  scheduledTime   String
  status          String   @default("pending")
  calendarEventId String?
  type            String   @default("order")
  deliveryAddress String?
  forwardedTo     String?
  createdAt       DateTime @default(now())
}

// Estoque
model StockItem {
  id          String       @id @default(cuid())
  name        String
  unit        String       @default("kg")
  quantity    Float        @default(0)
  minQuantity Float        @default(1)
  ingredients Ingredient[]
}

model Product {
  id          String       @id @default(cuid())
  name        String
  unit        String       @default("unidade")
  ingredients Ingredient[]
}

model Ingredient {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  quantityPer Float
}

// Disponibilidade de horários
model AvailableSlot {
  id        String @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  maxOrders Int    @default(3)
}

// Cache local dos eventos do Google Calendar
model CalendarEvent {
  id          String   @id
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  syncedAt    DateTime @default(now())
}

// Legado
model CakeOrder {
  id           Int      @id @default(autoincrement())
  clientName   String
  deliveryDate String
  cakeType     String
  quantity     String?
  sender       String?
  createdAt    DateTime @default(now())
}

model Setting {
  id              String  @id @default("global")
  openaiKey       String?
  claudeKey       String?
  activeModel     String  @default("openai")
  // Google Calendar OAuth
  gcalEnabled     Boolean @default(false)
  gcalClientId    String?
  gcalClientSecret String?
  gcalAccessToken  String?
  gcalRefreshToken String?
  gcalTokenExpiry  String?
  gcalCalendarId  String?
  gcalSyncHour    Int     @default(6)
  // Negócio
  businessName    String?
  managerJid      String?
  deliveryJid     String?
  reportEnabled   Boolean @default(false)
  reportHour      Int     @default(7)
}
