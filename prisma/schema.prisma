generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Instance {
  id        String    @id @default(uuid())
  name      String
  status    String    @default("disconnected")
  color     String    @default("#3b82f6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  botPrompt String?   @db.Text
  knowledge String?   @db.LongText
  chats     Chat[]
  flows     Flow[]
  messages  Message[]

  @@map("instance")
}

model Flow {
  id         String    @id @default(uuid())
  name       String
  trigger    String    @default("whatsapp.inbound")
  status     String    @default("Rascunho")
  data       String    @db.LongText
  instanceId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  instance   Instance? @relation(fields: [instanceId], references: [id])

  @@map("flow")
}

model Chat {
  id          String    @id @default(uuid())
  instanceId  String
  jid         String
  name        String?
  unreadCount Int       @default(0)
  lastMsg     String?
  lastMsgTime String?
  aiEnabled   Boolean   @default(false)
  adminJid    String?
  isGroup     Boolean   @default(false)
  lastPixAnalysis String?  @db.Text
  updatedAt   DateTime  @updatedAt
  instance    Instance  @relation(fields: [instanceId], references: [id])
  messages    Message[]

  @@unique([instanceId, jid])
  @@map("chat")
}

model Message {
  id                String   @id @default(uuid())
  msgId             String   @unique
  instanceId        String
  jid               String
  text              String   @db.Text
  fromMe            Boolean
  participant       String?
  senderName        String?
  quotedText        String?
  quotedParticipant String?
  timestamp         DateTime @default(now())
  status            String   @default("sent")
  chat              Chat     @relation(fields: [instanceId, jid], references: [instanceId, jid])
  instance          Instance @relation(fields: [instanceId], references: [id])

  @@index([instanceId, jid])
  @@map("message")
}

model Order {
  id              String    @id @default(cuid())
  instanceId      String
  clientName      String?
  clientJid       String?
  productId       String?
  product         String
  quantity        String?
  notes           String?
  scheduledDate   String
  scheduledTime   String
  status          String    @default("pending")
  calendarEventId String?
  type            String    @default("order")
  deliveryAddress String?
  forwardedTo     String?
  reminderSent    Boolean   @default(false)
  totalValue      Float     @default(0)
  deliveryFee     Float     @default(0)
  paymentMethod   String?
  paymentStatus   String    @default("pending")
  massa           String?
  recheio         String?
  topo            String?
  createdAt       DateTime  @default(now())
  productRelation Product?  @relation(fields: [productId], references: [id])
  customer        Customer? @relation(fields: [clientJid], references: [jid])
  @@map("order")
}

model Customer {
  id               String   @id @default(cuid())
  jid              String   @unique
  name             String?
  address          String?
  lastDeliveryFee  Float?   @default(0)
  paymentMethod    String?
  lastOrderDate    DateTime?
  preferredProduct String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]

  @@map("customer")
}

model StockItem {
  id          String       @id @default(cuid())
  name        String
  unit        String       @default("kg")
  quantity    Float        @default(0)
  minQuantity Float        @default(1)
  ingredients Ingredient[]
  @@map("stockitem")
}

model Product {
  id           String       @id @default(cuid())
  name         String
  type         String       @default("encomenda")
  unit         String       @default("unidade")
  price        Float        @default(0)
  stock        Int          @default(0)
  capacityCost Int          @default(1)
  prepTime     Int          @default(30)
  description  String?
  variations   String?      @db.Text
  comboItems   String?      @db.Text
  ingredients  Ingredient[]
  orders       Order[]
  @@map("product")
}

model Ingredient {
  id          String    @id @default(cuid())
  productId   String
  stockItemId String
  quantityPer Float
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("ingredient")
}

model AvailableSlot {
  id        String @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  maxOrders Int    @default(3)
  @@map("availableslot")
}

model CalendarEvent {
  id          String   @id
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  syncedAt    DateTime @default(now())
  @@map("calendarevent")
}

model CakeOrder {
  id           Int      @id @default(autoincrement())
  clientName   String
  deliveryDate String
  cakeType     String
  quantity     String?
  sender       String?
  createdAt    DateTime @default(now())
  @@map("cakeorder")
}

model Setting {
  id                 String  @id @default("global")
  openaiKey          String? @db.Text
  claudeKey          String? @db.Text
  mercadopagoToken   String? @db.Text
  mercadopagoPublicKey String? @db.Text
  activeModel        String  @default("openai")
  gcalEnabled        Boolean @default(false)
  gcalClientId       String? @db.Text
  gcalClientSecret   String? @db.Text
  gcalAccessToken    String? @db.Text
  gcalRefreshToken   String? @db.Text
  gcalTokenExpiry    String? @db.Text
  gcalCalendarId     String?
  gcalSyncHour       Int     @default(6)
  businessName       String?
  businessAddress    String?
  businessLocation   String?
  googleApiKey       String? @default("")
  deliveryRules      String? @db.Text // JSON: [{ maxKm: 3, fee: 5 }]
  managerJid         String?
  deliveryJid        String?
  dailyMaxOrders     Int     @default(10)
  maxDeliveryKm      Float   @default(15.0)
  dailyDeliveryItems String? @db.Text
  reportEnabled      Boolean @default(false)
  reportHour         Int     @default(7)
  reminderHours      Int     @default(2)
  pixReceiverName    String? @db.Text
  pixReceiverKey     String? @db.Text
  @@map("setting")
}

model MarketingAsset {
  id        String   @id @default(uuid())
  name      String   // Nome que você usará para pedir à Lily (ex: "Vulcão")
  path      String   // Caminho da imagem no servidor
  createdAt DateTime @default(now())
  @@map("marketingasset")
}

model FlowState {
  id            String    @id @default(uuid())
  instanceId    String
  jid           String
  flowId        String
  currentNodeId String
  resumeAt      DateTime?
  updatedAt     DateTime  @updatedAt

  @@unique([instanceId, jid])
  @@map("flowstate")
}
